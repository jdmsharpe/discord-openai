# Environment variables example file - to be used as a template for .env file
BOT_TOKEN=your_value_here
GUILD_IDS=your_value_here
OPENAI_API_KEY=your_value_here

# Optional: Comma-separated vector store IDs used by /openai chat file_search
# Set this to enable the built-in file_search tool for chat requests
# OPENAI_VECTOR_STORE_IDS=vs_abc123,vs_def456

# MCP presets (optional) - configure remote MCP servers and OpenAI connectors for /openai chat
# Provide presets as inline JSON or as a path to a JSON file (both are additive, no duplicate names allowed)
# OPENAI_MCP_PRESETS_JSON=
# OPENAI_MCP_PRESETS_PATH=config/mcp-presets.json

# Optional: Show cost and token usage embeds on chat, image, speech, and video responses (default: true; accepts true/1/yes)
# SHOW_COST_EMBEDS=true

# Optional: Path to a pricing YAML that overrides the bundled src/discord_openai/config/pricing.yaml
# Useful for pushing a vendor price change without waiting for a code release
# OPENAI_PRICING_PATH=./config/custom-pricing.yaml

# Optional: Logging format. "text" (default) for human-readable; "json" for structured JSON-lines
# Log records include a request_id that is bound per slash-command and on_message handler
# LOG_FORMAT=json
